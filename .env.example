ANTHROPIC_API_KEY=sk-ant-...
GCP_PROJECT=your-gcp-project-id

# Local dev: point to your service account key file
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\your-service-account-key.json

# Cloud deploy (e.g. Streamlit Community Cloud): paste the full key file
# contents here instead, as a string. Takes priority over the file path above.
# GOOGLE_CREDENTIALS_JSON={"type": "service_account", ...}
